{
    "python.analysis.extraPaths": [
        "repairperson-simulator-app/.venv/lib/python3.12/site-packages"
    ],
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.inlayHints.pytestParameters": true,
    "python.languageServer": "Pylance",
    "python.testing.autoTestDiscoverOnSaveEnabled": true,
    "python.testing.autoTestDiscoverOnSavePattern": "repairperson-simulator-app/**/test_*.py",
    // "python.testing.cwd": "./repairperson-simulator-app",
    "python.testing.pytestArgs": [
        "repairperson-simulator-app"
    ],
    // "python.testing.pytestPath": "./repairperson-simulator-app/.venv/lib/python3.12/site-packages",
    "python.testing.pytestPath": "./repairperson-simulator-app/.venv/bin/pytest",
    // "python.testing.pytestPath": "${workspaceFolder}/repairperson-simulator-app/.venv/bin/pytest",
    "python.testing.unittestEnabled": false,
    "python.testing.pytestEnabled": true,
    "python-envs.defaultEnvManager": "ms-python.python:system",
    "python-envs.pythonProjects": []
}
